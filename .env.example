# OpenAI-compatible Hugging Face Router endpoint
API_BASE_URL=https://router.huggingface.co/v1

# Real Hugging Face access token (starts with hf_)
API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional model override
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Submission mode: fail if remote proxy auth/init fails
REQUIRE_REMOTE_LLM=1
